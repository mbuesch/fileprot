[Unit]
Description=fileprot - File Protection FUSE Daemon
After=dbus.service
Requires=dbus.service

[Service]
Type=simple
ExecStart=/opt/fileprot/bin/fileprotd
Restart=on-failure
RestartSec=5

# Security hardening
NoNewPrivileges=yes
ProtectSystem=strict
ProtectHome=yes
PrivateTmp=yes
ReadWritePaths=/var/lib/fileprot

[Install]
WantedBy=multi-user.target
