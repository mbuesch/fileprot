#
# fileprotd configuration file
#
#

# Path to the GUI binary.
# Used for D-Bus peer verification to ensure only the legitimate GUI can
# approve/reject access requests.
#
gui_binary_path = "/opt/fileprot/bin/fileprot"

# Timeout in seconds for access requests.
# If no response is received within this time, the request is automatically denied.
#
request_timeout_secs = 120

# How long (in seconds) to remember an approval for a specific process without
# prompting again. The cached approval is bound to the PID, UID, executable
# path, and process start time, so PID reuse cannot bypass it.
# Set to 0 to disable approval caching entirely.
# Default: 10
#
#approval_ttl_secs = 10

# When true (the default), a cached approval is coupled to the exact process
# that obtained it: PID, UID, executable path, and process start time must all
# match before the cached approval is reused.
# When false, any process may reuse a recently-granted approval within the TTL
# window. Only disable this if you fully trust all processes on the system.
# Default: true
#
#couple_approval_to_process = true

# Base directory for all backing storage on the host filesystem.
# Mount backing_dir values that are relative paths are resolved against this directory.
#
backing_base_dir = "/opt/fileprot/var/lib/fileprot-backing"


# Each [[mount]] section defines a protected FUSE filesystem.
#
[[mount]]
# disabled: When true, this mount will not be activated by the daemon.
# Uncomment and set to true to disable this mount.
#
#disabled = true

# name: A unique identifier for this mount.
# Used as the default backing directory name if `backing_dir` is not supplied.
#
name = "protected"

# mountpoint: the path where the FUSE filesystem will be mounted.
#
mountpoint = "/mnt/protected"

# backing_dir: Directory under `backing_base_dir` where the backing store for this mount is kept.
# If omitted, it defaults to the value of `name` (above).
# Use an absolute path to override `backing_base_dir`.
#
#backing_dir = "protected"

# uid: Owner user for the mounted filesystem.
# Accepts a numeric uid or a user name string.
# Defaults to 0 (root) if not set.
#
#uid = "myuser"
#uid = "1000"

# gid: Owner group for the mounted filesystem.
# Accepts a numeric gid or a group name string.
# Defaults to 0 (root) if not set.
#
#gid = "mygroup"
#gid = "1000"



[[mount]]
disabled = true # This mount is disabled
name = "another_protected"
mountpoint = "/mnt/another_protected"
